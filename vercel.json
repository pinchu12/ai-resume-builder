{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "env": {
    "VITE_API_URL": "http://localhost:5000"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://resume-api.vercel.app/api/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/"
    }
  ]
}
